# Vonage SMS Webhook - Environment Variables
# Copy this file to .env.local and fill in your values

# Vonage API credentials - found at https://dashboard.nexmo.com
VONAGE_API_KEY=your_api_key_here
VONAGE_API_SECRET=your_api_secret_here

# Your Vonage virtual number (the number you purchased)
VONAGE_FROM_NUMBER=55219XXXXXXXX
# Exposed to the browser — used to display your number in the UI
NEXT_PUBLIC_FROM_NUMBER=55219XXXXXXXX

# Secret appended to the webhook URL: /api/webhook?secret=<value>
# Configure this same value in the Vonage dashboard webhook URL.
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=replace_with_a_random_secret

# Bearer token used by the frontend to authenticate calls to /api/send-sms and /api/messages.
# Both variables must have the SAME value.
# Generate with: openssl rand -hex 32
API_SECRET=replace_with_a_random_secret
# Exposed to the browser bundle — must match API_SECRET
NEXT_PUBLIC_API_SECRET=replace_with_a_random_secret

# Comma-separated allowed dev origins (e.g. ngrok tunnel URL — dev only)
# Use ONLY THE HOSTNAME, without https:// and without trailing slash
# Example: ALLOWED_DEV_ORIGINS=xxxx.ngrok-free.app
ALLOWED_DEV_ORIGINS=
